ACTIONS = {
    "up": "input swipe 540 1800 540 400",
    "down": "input swipe 540 400 540 1800",
    "left": "input swipe 900 1196 100 1196",
    "right": "input swipe 100 1196 900 1196",
    "volup": "input keyevent KEYCODE_VOLUME_UP",
    "voldown": "input keyevent KEYCODE_VOLUME_DOWN",
    "power": "input keyevent KEYCODE_POWER",
    "back": "input keyevent KEYCODE_BACK",
    "home": "input keyevent KEYCODE_HOME",
}


class ReuseTCPServer(socketserver.ThreadingTCPServer):
    allow_reuse_address = True
    daemon_threads = True


class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path in ("/", "/index.html"):
            body = HTML.encode("utf-8")
            self.send_response(HTTPStatus.OK)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        self.send_error(HTTPStatus.NOT_FOUND)

    def log_message(self, fmt, *args):
        return


def run_http():
    with ReuseTCPServer(("127.0.0.1", HTTP_PORT), Handler) as httpd:
        httpd.serve_forever()


def adb_connect():
    subprocess.run(
        ["adb", "connect", ADB_SERIAL],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )


def launch_scrcpy():
    subprocess.Popen(SCRCPY_CMD, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def launch_brave():
    subprocess.Popen(BRAVE_CMD, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


async def send_line(ws: WebSocketServerProtocol, kind: str, text: str):
    await ws.send(json.dumps({"kind": kind, "data": text}))


async def pump_stream(ws: WebSocketServerProtocol, stream, kind: str):
    while True:
        line = await stream.readline()
        if not line:
            break
        await send_line(ws, kind, line.decode("utf-8", errors="replace").rstrip("\n"))


async def handle_ws(ws: WebSocketServerProtocol):
    proc = await asyncio.create_subprocess_exec(
        *SSH_CMD,
        stdin=asyncio.subprocess.PIPE,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.PIPE,
    )
    stdout_task = asyncio.create_task(pump_stream(ws, proc.stdout, "out"))
    stderr_task = asyncio.create_task(pump_stream(ws, proc.stderr, "err"))
    await send_line(ws, "info", "hi phone shell ready")

    try:
        async for raw in ws:
            data = json.loads(raw)
            msg_type = data.get("type")
            if msg_type == "cmd":
                proc.stdin.write((data.get("cmd", "") + "\n").encode())
                await proc.stdin.drain()
            elif msg_type == "action":
                action = ACTIONS.get(data.get("action"))
                if action:
                    proc.stdin.write((action + "\n").encode())
                    await proc.stdin.drain()
            elif msg_type == "screen":
                launch_scrcpy()
                await send_line(ws, "ok", "scrcpy launched")
            elif msg_type == "screenshot":
                proc.stdin.write(b"screencap -p > /sdcard/Download/controller-shot.png\n")
                await proc.stdin.drain()
                await send_line(ws, "ok", "/sdcard/Download/controller-shot.png")
    finally:
        stdout_task.cancel()
        stderr_task.cancel()
        if proc.stdin:
            proc.stdin.close()
        with contextlib.suppress(ProcessLookupError):
            proc.terminate()
        with contextlib.suppress(Exception):
            await asyncio.wait_for(proc.wait(), timeout=3)
        if proc.returncode is None:
            with contextlib.suppress(ProcessLookupError):
                proc.kill()


async def main_async():
    server = await websockets.serve(handle_ws, "127.0.0.1", WS_PORT, ping_interval=20, ping_timeout=20)
    await server.wait_closed()


def main():
    adb_connect()
    threading.Thread(target=run_http, daemon=True).start()
    launch_scrcpy()
    time.sleep(1)
    launch_brave()
    asyncio.run(main_async())


if __name__ == "__main__":
    import contextlib
    main()
