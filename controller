# ── HTTP server ───────────────────────────────────────────────────────────────
_scrcpy_proc: subprocess.Popen | None = None

class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, fmt, *args): pass  # silence access log

    def _json(self, obj: dict, status: int = 200):
        body = json.dumps(obj).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        if self.path in ("/", "/index.html"):
            body = HTML.encode()
            self.send_response(HTTPStatus.OK)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        else:
            self.send_response(HTTPStatus.NOT_FOUND)
            self.end_headers()

    def do_POST(self):
        global _scrcpy_proc
        p = self.path

        if p == "/api/screen/start":
            if _scrcpy_proc and _scrcpy_proc.poll() is None:
                self._json({"ok": True, "msg": "already running"})
                return
            # connect ADB first (best-effort)
            subprocess.run(["adb", "connect", ADB_SERIAL],
                           capture_output=True, timeout=5)
            try:
                _scrcpy_proc = subprocess.Popen(
                    ["scrcpy", "-s", ADB_SERIAL,
                     "--stay-awake", "--window-title", "controller",
                     "--max-size", "1280", "--video-bit-rate", "8M"],
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
                )
                self._json({"ok": True, "pid": _scrcpy_proc.pid})
            except Exception as e:
                self._json({"ok": False, "error": str(e)}, 500)

        elif p == "/api/screen/stop":
            if _scrcpy_proc:
                _scrcpy_proc.terminate()
                _scrcpy_proc = None
            self._json({"ok": True})

        elif p == "/api/screenshot":
            import datetime, shlex
            ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
            out_dir = pathlib.Path.home() / "Desktop" / "ControllerCaptures"
            out_dir.mkdir(exist_ok=True)
            out = out_dir / f"shot_{ts}.png"
            try:
                subprocess.run(
                    ["bash", "-c",
                     f"adb -s {shlex.quote(ADB_SERIAL)} exec-out screencap -p > {shlex.quote(str(out))}"],
                    check=True, timeout=15
                )
                self._json({"ok": True, "file": str(out)})
            except Exception as e:
                self._json({"ok": False, "error": str(e)}, 500)
        else:
            self.send_response(HTTPStatus.NOT_FOUND)
            self.end_headers()


def run_http():
    with socketserver.TCPServer(("127.0.0.1", HTTP_PORT), Handler) as srv:
        srv.serve_forever()


# ── WebSocket SSH terminal ────────────────────────────────────────────────────
async def ws_handler(websocket):
    """One SSH session per WS connection."""
    ssh_args = [
        "ssh",
        "-i", SSH_KEY,
        "-o", "BatchMode=yes",
        "-o", "StrictHostKeyChecking=accept-new",
        "-o", "ConnectTimeout=8",
        "-p", PHONE_PORT,
        f"{PHONE_USER}@{PHONE_IP}",
    ]
    proc = await asyncio.create_subprocess_exec(
        *ssh_args,
        stdin=asyncio.subprocess.PIPE,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.PIPE,
    )

    async def pipe_stream(stream, label):
        while True:
            line = await stream.readline()
            if not line:
                break
            await websocket.send(json.dumps({"stream": label, "data": line.decode(errors="replace")}))

    async def recv_cmds():
        try:
            async for msg in websocket:
                try:
                    obj = json.loads(msg)
                    cmd = obj.get("cmd", "")
                    if cmd and proc.stdin:
                        proc.stdin.write((cmd + "\n").encode())
                        await proc.stdin.drain()
                except Exception:
                    pass
        except Exception:
            pass
        if proc.returncode is None:
            proc.terminate()

    await asyncio.gather(
        pipe_stream(proc.stdout, "stdout"),
        pipe_stream(proc.stderr, "stderr"),
        recv_cmds(),
    )
    await proc.wait()


async def run_ws():
    import websockets
    async with websockets.serve(ws_handler, "127.0.0.1", WS_PORT):
        await asyncio.get_event_loop().create_future()  # run forever


