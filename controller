async def handle_client(sock):
    ssh_cmd = [
        "ssh",
        "-i",
        SSH_KEY,
        "-o",
        "StrictHostKeyChecking=no",
        "-o",
        "UserKnownHostsFile=/dev/null",
        "-o",
        "ServerAliveInterval=30",
        "-p",
        PHONE_PORT,
        f"{PHONE_USER}@{PHONE_IP}",
    ]
    proc = await asyncio.create_subprocess_exec(
        *ssh_cmd,
        stdin=asyncio.subprocess.PIPE,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.PIPE,
    )
    stdout_task = asyncio.create_task(stream_pipe(proc.stdout, sock, "out"))
    stderr_task = asyncio.create_task(stream_pipe(proc.stderr, sock, "err"))
    ws_send(sock, json.dumps({"kind": "info", "data": "hi phone shell ready"}))

    try:
        while True:
            message = await asyncio.to_thread(ws_recv, sock)
            if message is None:
                break
            if not message:
                continue
            data = json.loads(message)
            msg_type = data.get("type")
            if msg_type == "cmd":
                cmd = data.get("cmd", "")
                proc.stdin.write((cmd + "\n").encode())
                await proc.stdin.drain()
            elif msg_type == "screen":
                await launch_scrcpy()
                ws_send(sock, json.dumps({"kind": "ok", "data": "scrcpy launched"}))
            elif msg_type == "screenshot":
                proc.stdin.write(b"screencap -p > /sdcard/Download/controller-shot.png\n")
                await proc.stdin.drain()
                ws_send(sock, json.dumps({"kind": "ok", "data": "/sdcard/Download/controller-shot.png"}))
    finally:
        if proc.stdin:
            proc.stdin.close()
        proc.terminate()
        await proc.wait()
        stdout_task.cancel()
        stderr_task.cancel()
        sock.close()


async def ws_server():
    server = await asyncio.start_server(handle_ws, "127.0.0.1", WS_PORT)
    async with server:
        await server.serve_forever()


async def handle_ws(reader, writer):
    req = b""
    while b"\r\n\r\n" not in req:
        chunk = await reader.read(4096)
        if not chunk:
            writer.close()
            await writer.wait_closed()
            return
        req += chunk
    headers = req.decode("utf-8", errors="replace").split("\r\n")
    key = None
    for line in headers:
        if line.lower().startswith("sec-websocket-key:"):
            key = line.split(":", 1)[1].strip()
            break
    if not key:
        writer.close()
        await writer.wait_closed()
        return
    response = (
        "HTTP/1.1 101 Switching Protocols\r\n"
        "Upgrade: websocket\r\n"
        "Connection: Upgrade\r\n"
        f"Sec-WebSocket-Accept: {b64_sha1_accept(key)}\r\n\r\n"
    )
    writer.write(response.encode("utf-8"))
    await writer.drain()
    sock = writer.get_extra_info("socket")
    sock.setblocking(True)
    await handle_client(sock)
    writer.close()
    await writer.wait_closed()


