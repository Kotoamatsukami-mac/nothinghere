const shotBtn = document.getElementById('shot');
const controls = document.querySelectorAll('[data-action]');
let ws = null;
let reconnectDelay = 5000;
let reconnectTimer = null;
let intentionalClose = false;

function appendLine(text, cls = 'out') {
  const line = document.createElement('div');
  line.className = `line ${cls}`;
  line.textContent = text;
  terminalEl.appendChild(line);
  terminalEl.scrollTop = terminalEl.scrollHeight;
}

function setLive(live) {
  dotEl.classList.toggle('live', live);
}

function send(payload) {
  if (!ws || ws.readyState !== WebSocket.OPEN) {
    appendLine('offline', 'err');
    return;
  }
  ws.send(JSON.stringify(payload));
}

function scheduleReconnect() {
  if (intentionalClose || reconnectTimer) return;
  reconnectTimer = setTimeout(() => {
    reconnectTimer = null;
    connect();
  }, reconnectDelay);
}

function connect() {
  if (ws && (ws.readyState === WebSocket.OPEN || ws.readyState === WebSocket.CONNECTING)) return;
  appendLine('connecting…', 'info');
  ws = new WebSocket('ws://127.0.0.1:7780');
  ws.onopen = () => {
    setLive(true);
    appendLine('ssh connected', 'ok');
  };
  ws.onmessage = (event) => {
    try {
      const msg = JSON.parse(event.data);
      appendLine(msg.data || '', msg.kind || 'out');
    } catch {
      appendLine(String(event.data || ''), 'out');
    }
  };
  ws.onerror = () => appendLine('ws error', 'err');
  ws.onclose = () => {
    setLive(false);
    ws = null;
    appendLine('ssh disconnected', 'info');
    scheduleReconnect();
  };
}

screenBtn.addEventListener('click', () => send({type: 'screen'}));
