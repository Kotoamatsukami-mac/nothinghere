class ReuseTCPServer(socketserver.ThreadingTCPServer):
    allow_reuse_address = True
    daemon_threads = True


def b64_sha1_accept(key: str) -> str:
    raw = (key + "258EAFA5-E914-47DA-95CA-C5AB0DC85B11").encode()
    return base64.b64encode(hashlib.sha1(raw).digest()).decode()


def ws_send(sock, text: str) -> None:
    data = text.encode("utf-8")
    header = bytearray([0x81])
    size = len(data)
    if size < 126:
        header.append(size)
    elif size < 65536:
        header.extend([126, (size >> 8) & 0xFF, size & 0xFF])
    else:
        header.append(127)
        header.extend(size.to_bytes(8, "big"))
    sock.sendall(header + data)


def ws_recv(sock):
    first = sock.recv(2)
    if not first:
        return None
    b1, b2 = first
    length = b2 & 0x7F
    if length == 126:
        length = int.from_bytes(sock.recv(2), "big")
    elif length == 127:
        length = int.from_bytes(sock.recv(8), "big")
    mask = sock.recv(4)
    payload = bytearray()
    while len(payload) < length:
        chunk = sock.recv(length - len(payload))
        if not chunk:
            return None
        payload.extend(chunk)
    for i in range(length):
        payload[i] ^= mask[i % 4]
    opcode = b1 & 0x0F
    if opcode == 0x8:
        return None
    if opcode == 0x9:
        sock.sendall(b"\x8A\x00")
        return ""
    return payload.decode("utf-8", errors="replace")


class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path in ("/", "/index.html"):
            body = HTML.encode("utf-8")
            self.send_response(HTTPStatus.OK)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        self.send_error(HTTPStatus.NOT_FOUND)

    def log_message(self, fmt, *args):
        return


async def stream_pipe(pipe, sock, kind):
    while True:
        line = await pipe.readline()
        if not line:
            break
        text = line.decode("utf-8", errors="replace").rstrip("\n")
        ws_send(sock, json.dumps({"kind": kind, "data": text}))


