#!/system/bin/sh
# np3a-toggle — double power-press → toggle full connection stack
# Stack = Tailscale VPN + Termux wakelock + sshd
# Single press handled by Android (sleep/wake) — we only intercept double

EVDEV=/dev/input/event1   # pmic_pwrkey
LOG=/data/local/tmp/np3a-toggle.log
STATE=/data/local/tmp/np3a-state/toggle_state
TU=u0_a296
TERMUX_PATH=/data/data/com.termux/files/usr/bin:/system/bin
TS_PKG=com.tailscale.ipn
WINDOW_MS=600   # double-press window in ms

mkdir -p /data/local/tmp/np3a-state

trim_log() {
  [ -f "$LOG" ] && tail -300 "$LOG" > "$LOG.tmp" && mv "$LOG.tmp" "$LOG"
}

ts_ms() {
  # milliseconds since epoch
  date +%s%3N 2>/dev/null || echo 0
}

stack_status() {
  # returns: up | down
  ts_running="$(su $TU -c "PATH=$TERMUX_PATH tailscale status 2>/dev/null" | grep -c "^100\." || true)"
  sshd_up="$(ss -ltnp 2>/dev/null | grep -c ':8022' || true)"
  if [ "${ts_running:-0}" -gt 0 ] && [ "${sshd_up:-0}" -gt 0 ]; then
    echo "up"
  else
    echo "down"
  fi
}

stack_up() {
  echo "stack_up $(date '+%H:%M:%S')" >> "$LOG"
  # Tailscale connect
  su $TU -c "PATH=$TERMUX_PATH tailscale up 2>/dev/null" >/dev/null 2>&1 || \
    am start -n "$TS_PKG/.MainActivity" >/dev/null 2>&1 || true
  sleep 2
  # sshd
  if ! ss -ltnp 2>/dev/null | grep -q ':8022'; then
    su "$TU" -c "PATH=$TERMUX_PATH sshd" >/dev/null 2>&1 && echo "sshd started" >> "$LOG"
  fi
  # wakelock
  su "$TU" -c "PATH=$TERMUX_PATH termux-wake-lock" >/dev/null 2>&1 || true
  # Glyph feedback: 3 quick flashes via nothing glyph (if available)
  cmd notification post -S bigtext -t nhere -I nhere "Connection UP" >/dev/null 2>&1 || true
  echo "stack UP complete" >> "$LOG"
  echo "up" > "$STATE"
}

stack_down() {
  echo "stack_down $(date '+%H:%M:%S')" >> "$LOG"
  # Tailscale disconnect
  su $TU -c "PATH=$TERMUX_PATH tailscale down 2>/dev/null" >/dev/null 2>&1 || true
  # Kill sshd
  pkill -f "sshd" 2>/dev/null || true
  # Release wakelock
  su "$TU" -c "PATH=$TERMUX_PATH termux-wake-unlock" >/dev/null 2>&1 || true
  cmd notification post -S bigtext -t nhere -I nhere "Connection DOWN" >/dev/null 2>&1 || true
  echo "stack DOWN complete" >> "$LOG"
  echo "down" > "$STATE"
}

toggle() {
  current="$(stack_status)"
  echo "toggle triggered — current=$current" >> "$LOG"
  if [ "$current" = "up" ]; then
    stack_down &
  else
    stack_up &
  fi
}

trim_log
echo "np3a-toggle started $(date)" >> "$LOG"

LAST_PRESS=0
getevent -q "$EVDEV" 2>/dev/null | while read type code value; do
  # KEY_POWER press: type=0001 code=0074 value=00000001
  if [ "$type" = "0001" ] && [ "$code" = "0074" ] && [ "$value" = "00000001" ]; then
    NOW="$(ts_ms)"
    DIFF=$((NOW - LAST_PRESS))
    echo "power press diff=${DIFF}ms" >> "$LOG"
    if [ "$DIFF" -lt "$WINDOW_MS" ] && [ "$LAST_PRESS" -gt 0 ]; then
      echo "double-press detected" >> "$LOG"
      LAST_PRESS=0
      toggle
    else
      LAST_PRESS="$NOW"
    fi
  fi
done
