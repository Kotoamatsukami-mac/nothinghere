#!/bin/sh
# phone-side/agent — phone engine, non-daemon
# Deploy: ~/nhere/agent  chmod +x
# Commands: ping | status

# Bootstrap Termux bin path — non-interactive SSH strips PATH
TERMUX_BIN="/data/data/com.termux/files/usr/bin"
[ -d "$TERMUX_BIN" ] && export PATH="$TERMUX_BIN:$PATH"

CMD="${1:-status}"

utctime() { date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u; }

battery_state() {
  if command -v termux-battery-status >/dev/null 2>&1; then
    bat_raw="$(termux-battery-status 2>/dev/null)"
    [ -z "$bat_raw" ] && { echo "unknown (no output)"; return; }
    bat_pct="$(printf '%s' "$bat_raw" | grep -o '"percentage":[[:space:]]*[0-9]*' | grep -o '[0-9]*')"
    bat_st="$(printf  '%s' "$bat_raw" | grep -o '"status":[[:space:]]*"[^"]*"' | sed 's/.*"\([^"]*\)"$/\1/')"
    printf '%s%% %s' "${bat_pct:---}" "${bat_st:---}"
  else
    echo "unknown (pkg install termux-api)"
  fi
}

root_state() {
  command -v su >/dev/null 2>&1 || { echo "unavailable (su not found)"; return; }
  if command -v timeout >/dev/null 2>&1; then
    root_id="$(timeout 3 su -c id 2>/dev/null | grep -o 'uid=[0-9]*' | head -1)"
  else
    root_id="$(su -c id 2>/dev/null | grep -o 'uid=[0-9]*' | head -1)"
  fi
  case "$root_id" in
    uid=0) echo "available" ;;
    "")    echo "unavailable" ;;
    *)     echo "partial ($root_id)" ;;
  esac
}

# tun0 = Android VPN interface for Tailscale.
# Tailscale CLI cannot reach Android VPN daemon IPC from Termux userland.
# ifconfig <iface> not supported by Termux busybox — use no-arg form + awk.
tailscale_state() {
  ts_ip="$(ifconfig 2>/dev/null | awk '/^tun0/{f=1} f && /inet /{print $2; exit}')"
  if [ -n "$ts_ip" ]; then
    printf 'up  tun0  %s' "$ts_ip"
  else
    echo "down (tun0 not found)"
  fi
}

# netstat -an cannot read /proc/net without elevated perms on Android.
# pgrep -x sshd is reliable — sshd managed by runit (runsv) in Termux.
sshd_state() {
  port="${NHERE_PORT:-8022}"
  if pgrep -x sshd >/dev/null 2>&1; then
    echo "listening :${port}"
  else
    echo "not running"
  fi
}

# dumpsys not in Termux PATH — deferred until su -c path wired in next patch
wakelock_state() {
  echo "deferred"
}

armed_state() {
  ts="$(tailscale_state)"
  ssh_st="$(sshd_state)"
  ts_up=0; ssh_up=0
  printf '%s' "$ts"     | grep -q '^up'        && ts_up=1
  printf '%s' "$ssh_st" | grep -q '^listening' && ssh_up=1
  if   [ "$ts_up" = "1" ] && [ "$ssh_up" = "1" ]; then echo "armed"
  elif [ "$ts_up" = "1" ]; then echo "degraded (sshd not running)"
  else echo "degraded (tailscale down)"
  fi
}

case "$CMD" in
  ping)   printf 'pong %s\n' "$(utctime)" ;;
  status)
    printf 'host:       %s\n' "$(hostname 2>/dev/null || echo unknown)"
    printf 'time:       %s\n' "$(utctime)"
    printf 'state:      %s\n' "$(armed_state)"
    printf 'battery:    %s\n' "$(battery_state)"
    printf 'root:       %s\n' "$(root_state)"
    printf 'tailscale:  %s\n' "$(tailscale_state)"
    printf 'sshd:       %s\n' "$(sshd_state)"
    printf 'wakelock:   %s\n' "$(wakelock_state)"
    ;;
  *)
    printf 'error: unknown command: %s\n' "$CMD" >&2; exit 1 ;;
esac
