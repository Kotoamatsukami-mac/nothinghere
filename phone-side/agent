#!/bin/sh
# phone-side/agent — phone engine, non-daemon
# Deploy: ~/nhere/agent  chmod +x
# Commands: ping | status

CMD="${1:-status}"

utctime() { date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u; }

battery_state() {
  if command -v termux-battery-status >/dev/null 2>&1; then
    bat_raw="$(termux-battery-status 2>/dev/null)"
    [ -z "$bat_raw" ] && { echo "unknown (no output)"; return; }
    bat_pct="$(printf '%s' "$bat_raw" | grep -o '"percentage":[[:space:]]*[0-9]*' | grep -o '[0-9]*')"
    bat_st="$(printf '%s' "$bat_raw"  | grep -o '"status":[[:space:]]*"[^"]*"' | sed 's/.*"\([^"]*\)"$/\1/')"
    printf '%s%% %s' "${bat_pct:---}" "${bat_st:---}"
  else
    echo "unknown (termux-battery-status not found — install: pkg install termux-api)"
  fi
}

root_state() {
  command -v su >/dev/null 2>&1 || { echo "unavailable (su not found)"; return; }
  if command -v timeout >/dev/null 2>&1; then
    root_id="$(timeout 3 su -c id 2>/dev/null | grep -o 'uid=[0-9]*' | head -1)"
  else
    root_id="$(su -c id 2>/dev/null | grep -o 'uid=[0-9]*' | head -1)"
  fi
  case "$root_id" in
    uid=0) echo "available" ;;
    "")    echo "unavailable" ;;
    *)     echo "partial ($root_id)" ;;
  esac
}

tailscale_state() {
  ts_ip=""
  if command -v ifconfig >/dev/null 2>&1; then
    ts_ip="$(ifconfig tun0 2>/dev/null | awk '/inet /{print $2; exit}')"
  fi
  if [ -z "$ts_ip" ] && command -v ip >/dev/null 2>&1; then
    ts_ip="$(ip -4 addr show tun0 2>/dev/null | awk '/inet /{split($2,a,"/"); print a[1]; exit}')"
  fi
  if [ -n "$ts_ip" ]; then
    printf 'up  tun0  %s' "$ts_ip"
  else
    echo "down (tun0 not found)"
  fi
}

# Check sshd is listening on the expected port
sshd_state() {
  port="${NHERE_PORT:-8022}"
  if command -v ss >/dev/null 2>&1; then
    ss -tlnp 2>/dev/null | grep -q ":${port}" && echo "listening :${port}" || echo "not listening :${port}"
  elif command -v netstat >/dev/null 2>&1; then
    netstat -tlnp 2>/dev/null | grep -q ":${port}" && echo "listening :${port}" || echo "not listening :${port}"
  else
    echo "reachable (you are here — ss/netstat not available)"
  fi
}

# Read wakelock state via termux-wake-lock if available
wakelock_state() {
  # termux-wake-lock/unlock are actions, not state queries — check via PowerManager dump
  wl="$(dumpsys power 2>/dev/null | grep -i 'WakeLock' | grep -c 'HELD' 2>/dev/null || echo "")"
  if [ -n "$wl" ] && [ "$wl" -gt 0 ] 2>/dev/null; then
    printf 'held (%s lock(s))' "$wl"
  elif [ -n "$wl" ]; then
    echo "none held"
  else
    echo "unknown (dumpsys not available)"
  fi
}

armed_state() {
  ts="$(tailscale_state)"
  ssh_st="$(sshd_state)"
  ts_up=0; ssh_up=0
  printf '%s' "$ts"    | grep -q '^up'        && ts_up=1
  printf '%s' "$ssh_st"| grep -q '^listening' && ssh_up=1
  if [ "$ts_up" = "1" ] && [ "$ssh_up" = "1" ]; then
    echo "armed"
  elif [ "$ts_up" = "1" ]; then
    echo "degraded (sshd not listening)"
  else
    echo "degraded (tailscale down)"
  fi
}

case "$CMD" in
  ping)
    printf 'pong %s\n' "$(utctime)"
    ;;
  status)
    printf 'host:       %s\n' "$(hostname 2>/dev/null || echo unknown)"
    printf 'time:       %s\n' "$(utctime)"
    printf 'state:      %s\n' "$(armed_state)"
    printf 'battery:    %s\n' "$(battery_state)"
    printf 'root:       %s\n' "$(root_state)"
    printf 'tailscale:  %s\n' "$(tailscale_state)"
    printf 'sshd:       %s\n' "$(sshd_state)"
    printf 'wakelock:   %s\n' "$(wakelock_state)"
    ;;
  *)
    printf 'error: unknown command: %s\n' "$CMD" >&2
    exit 1
    ;;
esac
