*.pem
*.key
id_*
*_ed25519
*_rsa
*_ecdsa
*.p12
*.pfx

# ─── Logs / temp ──────────────────────────────────────────────────────────────
*.log
logs/
tmp/
.tmp/
*.tmp

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ─── Recordings (cockpit captures) ────────────────────────────────────────────
recordings/*
!recordings/.gitkeep

# ─── Build artifacts ──────────────────────────────────────────────────────────
nhere*.zip

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
