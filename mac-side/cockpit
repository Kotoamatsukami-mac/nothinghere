    "    3) inline env:   NHERE_HOST_IP=... NHERE_USER=... NHERE_KEY=... ./mac-side/cockpit",
    "  (profile must use `export VAR=...` for source to work — see profiles/*.example.conf)",
  ].join("\n"));
  Deno.exit(1);
}
const HOST_IP = _hostIpRaw;
const NHERE_USER = Deno.env.get("NHERE_SSH_USER") ?? Deno.env.get("NHERE_USER") ?? "";
const NHERE_PORT = Deno.env.get("NHERE_SSH_PORT") ?? Deno.env.get("NHERE_PORT") ?? "8022";
const NHERE_KEY  = Deno.env.get("NHERE_SSH_KEY")  ?? Deno.env.get("NHERE_KEY")  ?? (Deno.env.get("HOME") + "/.ssh/nhere_ed25519");
const ADB_SERIAL = `${HOST_IP}:5555`;
// UI label for the device card header. Profiles can set NHERE_DEVICE_LABEL to
// override; falls back to the Tailscale hostname, then a generic label so the
// cockpit works for any Android, not just the Nothing 3a Pro.
