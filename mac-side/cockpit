<script>
let hls=null;
function setupHls(){
  const v=document.getElementById('vid'),src='/stream/stream.m3u8';
  if(typeof Hls!=='undefined'&&Hls.isSupported()){
    if(hls)hls.destroy();
    hls=new Hls({lowLatencyMode:true,liveSyncDurationCount:2});
    hls.loadSource(src);hls.attachMedia(v);
    hls.on(Hls.Events.MANIFEST_PARSED,()=>v.play().catch(()=>{}));
    hls.on(Hls.Events.ERROR,(_,d)=>{if(d.fatal)setOffline();});
  }else if(v.canPlayType('application/vnd.apple.mpegurl')){v.src=src;v.play().catch(()=>{});}
}
function setOnline(){document.getElementById('vid').style.display='';document.getElementById('op').style.display='none';setupHls();}
function setOffline(){document.getElementById('vid').style.display='none';document.getElementById('op').style.display='';if(hls){hls.destroy();hls=null;}}
function logCon(msg){const el=document.getElementById('con');if(el){el.textContent=msg;el.scrollTop=el.scrollHeight;}}
function logErr(msg){const el=document.getElementById('err');if(!el)return;if(msg){el.textContent=msg;el.style.display='';}else{el.textContent='';el.style.display='none';}}
async function fetchText(route){
  try{const r=await fetch(route);const t=(await r.text()).trim();if(!r.ok){logErr(route+': '+(t||r.status));return null;}logErr('');return t;}
  catch(e){logErr(route+': '+String(e));return null;}
}
async function apiShow(route){logCon(route+'...');const t=await fetchText(route);if(t!==null)logCon(t);}
async function apiReload(route){logCon(route+'...');const t=await fetchText(route);if(t!==null){logCon(t);setTimeout(()=>location.reload(),600);}}
async function streamStart(){
  logCon('/stream-start...');
  const t=await fetchText('/stream-start');
  if(!t||!t.startsWith('ok')){if(t!==null)logCon(t);return;}
  logCon(t+'\nwaiting for manifest...');
  // Action-scoped retry: poll the manifest every 300 ms for up to ~7 s.
  // Runs ONLY after the user pressed Start Stream — not a global polling loop.
  const deadline=Date.now()+7200;
  while(Date.now()<deadline){
    try{const r=await fetch('/stream/stream.m3u8',{cache:'no-store'});if(r.ok){logCon(t+'\nmanifest ready');logErr('');setOnline();return;}}catch{}
    await new Promise(r=>setTimeout(r,300));
  }
  logErr('stream process started but manifest not ready after ~7s. Check /tmp/cockpit.log, then press Start Stream again.');
}
async function streamStop(){logCon('/stream-stop...');const t=await fetchText('/stream-stop');if(t!==null)logCon(t);setOffline();}
function toggleFs(){const w=document.getElementById('vw');document.fullscreenElement?document.exitFullscreen():w.requestFullscreen().catch(()=>{});}
document.addEventListener('keydown',e=>{
  if(e.target.tagName==='INPUT')return;
  switch(e.key.toUpperCase()){
    case'L':apiReload('/arm');break;case'O':apiReload('/disarm');break;case'T':apiShow('/status');break;
    case'S':apiReload('/open-screen');break;case'X':apiReload('/close-screen');break;
    case'V':streamStart();break;case'Q':streamStop();break;
    case'R':apiShow('/record');break;case'P':apiShow('/ping');break;
    case' ':e.preventDefault();location.reload();break;
  }
});
${streamOn?"setOnline();":""}
</script></body></html>`;
}

async function handler(req: Request): Promise<Response> {
  const path = new URL(req.url).pathname;
  if (path.startsWith("/stream/")) {
    const fpath = `${STREAM_DIR}/${path.replace("/stream/","")}`;
    try {
      const data = await Deno.readFile(fpath);
      const ct = fpath.endsWith(".m3u8")?"application/vnd.apple.mpegurl":"video/mp2t";
      return new Response(data,{headers:{"Content-Type":ct,"Cache-Control":fpath.endsWith(".m3u8")?"no-cache":"max-age=2"}});
    } catch { return new Response("not found",{status:404}); }
  }
  if (path==="/stream.json") return new Response(JSON.stringify({alive:isPidAlive(streamPid),pid:streamPid}),{headers:{"Content-Type":"application/json","Cache-Control":"no-cache"}});
  if (path==="/stream-start") return new Response(await startStream(),{headers:{"Content-Type":"text/plain"}});
  if (path==="/stream-stop") { stopStream(); return new Response("stopped",{headers:{"Content-Type":"text/plain"}}); }
  if (path==="/"||path==="/index.html") {
    const fields=await getStatus();
    return new Response(buildHtml(fields,isPidAlive(streamPid),isPidAlive(relayPid),isPidAlive(recordingPid)),{headers:{"Content-Type":"text/html; charset=utf-8","Cache-Control":"no-cache"}});
  }
  if (path==="/status.json") {
    const fields=await getStatus();
    return new Response(JSON.stringify({raw:Object.entries(fields).map(([k,v])=>`${k}:       ${v}`).join("\n"),fields}),{headers:{"Content-Type":"application/json","Cache-Control":"no-cache"}});
  }
  // LIVE — try SSH first, fall back to ADB. Re-armable even after OFF as long
  // as ADB TCP was bootstrapped before disarm (the /disarm precheck below
  // enforces that, but ADB may also be enabled manually).
  if (path === "/arm") {
    const r = await nhereSafe("arm");
    const body = `[path=${r.path}]\n${r.out || r.err || "arm ok"}`;
    return new Response(body, { status: r.ok ? 200 : 502, headers: { "Content-Type": "text/plain" } });
  }

  // OFF — guarded. Hard rule: the cockpit must not disable its only control
  // path. We refuse the disarm unless an ADB fallback is confirmed reachable.
  if (path === "/disarm") {
    let adbCheck = await nhereOverAdb("status");
    if (!adbCheck.ok) {
      // Try to bootstrap ADB TCP via the still-up SSH connection, then retry.
      const relay = await nhereOverSsh("relay-prep");
      if (relay.ok) {
        await new Promise((r) => setTimeout(r, 2500));
        adbCheck = await nhereOverAdb("status");
      }
    }
    if (!adbCheck.ok) {
      const msg = [
        "OFF refused: SSH would be stopped and no ADB fallback is reachable.",
        "Run relay-prep, connect USB ADB, or use physical Termux recovery.",
      ].join("\n");
      return new Response(msg, { status: 412, headers: { "Content-Type": "text/plain" } });
    }
    // ADB fallback confirmed. Run the actual disarm over ADB so the response
    // path is not killed by sshd shutdown.
    const r = await nhereOverAdb("disarm");
    const body = `[path=${r.path}]\n${r.out || (r.ok ? "disarm ok" : "disarm failed")}`;
    return new Response(body, { status: r.ok ? 200 : 500, headers: { "Content-Type": "text/plain" } });
  }

  // STATUS — same SSH-first / ADB-fallback contract as /arm.
  if (path === "/status") {
    const r = await nhereSafe("status");
    const body = `[path=${r.path}]\n${r.out || r.err || ""}`;
    return new Response(body, { status: r.ok ? 200 : 502, headers: { "Content-Type": "text/plain" } });
  }

  // RELAY-PREP — manual recovery: turn on ADB TCP via SSH. Useful before any
  // OFF if the operator has not pre-armed an ADB fallback.
  if (path === "/relay-prep") {
    const r = await nhereSafe("relay-prep");
    const body = `[path=${r.path}]\n${r.out || r.err || ""}`;
    return new Response(body, { status: r.ok ? 200 : 502, headers: { "Content-Type": "text/plain" } });
  }
  if (path==="/ping") {
    const r=await run(["ssh","-i",NHERE_KEY,"-o","BatchMode=yes","-o","StrictHostKeyChecking=accept-new","-o","ConnectTimeout=5","-p",NHERE_PORT,`${NHERE_USER}@${HOST_IP}`,"true"]);
    return new Response(r.ok?"reachable":"unreachable",{headers:{"Content-Type":"text/plain"}});
  }
  if (path==="/open-screen") {
    if (isPidAlive(relayPid)) return new Response(`relay running pid=${relayPid}`,{headers:{"Content-Type":"text/plain"}});
    if (!(await scrcpyInstalled())) {
      return new Response("scrcpy not installed\n  install: brew install scrcpy", {status:500, headers:{"Content-Type":"text/plain"}});
    }
    await run(["adb","connect",ADB_SERIAL]);
    // Spawn detached so scrcpy does NOT block the cockpit server.
    const p=new Deno.Command("scrcpy",{args:["-s",ADB_SERIAL,"--window-title","Nothing Here Live"],stdout:"null",stderr:"null",stdin:"null"}).spawn();
    relayPid=p.pid;
    p.status.then(()=>{relayPid=null;}).catch(()=>{relayPid=null;});
    return new Response(`ok pid=${relayPid}`,{headers:{"Content-Type":"text/plain"}});
  }
  if (path==="/close-screen") { killPid(relayPid); relayPid=null; return new Response("closed",{headers:{"Content-Type":"text/plain"}}); }
  if (path==="/record") {
    if (isPidAlive(recordingPid)) return new Response("already recording",{headers:{"Content-Type":"text/plain"}});
    if (!(await scrcpyInstalled())) {
      return new Response("scrcpy not installed\n  install: brew install scrcpy", {status:500, headers:{"Content-Type":"text/plain"}});
    }
    await run(["adb","connect",ADB_SERIAL]);
    const ts=new Date().toISOString().replace(/[:.]/g,"-").slice(0,19);
    const out=`${RECORDINGS_DIR}/rec-${ts}.mp4`;
    const p=new Deno.Command("scrcpy",{args:["-s",ADB_SERIAL,"--no-display","--record",out],stdout:"null",stderr:"null",stdin:"null"}).spawn();
    recordingPid=p.pid;
    p.status.then(()=>{recordingPid=null;}).catch(()=>{recordingPid=null;});
    return new Response(`ok ${out}`,{headers:{"Content-Type":"text/plain"}});
  }
  if (path==="/stop-record") { killPid(recordingPid); recordingPid=null; return new Response("stopped",{headers:{"Content-Type":"text/plain"}}); }
  if (path==="/screenshot") {
    await run(["adb","connect",ADB_SERIAL]);
    const ts=new Date().toISOString().replace(/[:.]/g,"-").slice(0,19);
    const out=`${RECORDINGS_DIR}/shot-${ts}.png`;
    const p=new Deno.Command("bash",{args:["-c",`adb -s ${ADB_SERIAL} exec-out screencap -p > "${out}"`],stdout:"null",stderr:"null"});
    const {success}=await p.output();
    return new Response(success?`ok ${out}`:"failed",{headers:{"Content-Type":"text/plain"}});
  }
  return new Response("not found",{status:404});
}

console.log(`nothinghere cockpit :${PORT}`);
Deno.serve({port:PORT,hostname:"127.0.0.1"},handler);
