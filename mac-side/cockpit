let relayPid: number | null = null;
let recordingPid: number | null = null;
let streamPid: number | null = null;

function isPidAlive(pid: number | null): boolean {
  if (pid === null) return false;
  try { Deno.kill(pid, "SIGCONT"); return true; } catch { return false; }
}
function killPid(pid: number | null): void {
  if (pid === null) return;
  try { Deno.kill(pid, "SIGTERM"); } catch { /* dead */ }
}

async function run(cmd: string[], timeoutMs?: number): Promise<{ ok: boolean; out: string }> {
  try {
    const p = new Deno.Command(cmd[0], { args: cmd.slice(1), stdout: "piped", stderr: "piped" }).spawn();
    // Timeout protection. AbortSignal alone does NOT work for adb — it ignores
    // SIGTERM while blocked in connect() and rides out the OS TCP timeout (~75s
    // on macOS). Force-kill with SIGKILL instead, which adb cannot ignore.
    let killed = false;
    let timer: number | null = null;
    if (timeoutMs) {
      timer = setTimeout(() => { killed = true; try { p.kill("SIGKILL"); } catch { /* already dead */ } }, timeoutMs);
    }
    const { success, stdout, stderr } = await p.output();
    if (timer !== null) clearTimeout(timer);
    const out = (new TextDecoder().decode(stdout) + new TextDecoder().decode(stderr)).trim();
    return { ok: success && !killed, out: killed ? `timeout after ${timeoutMs}ms\n${out}` : out };
  } catch (e) { return { ok: false, out: String(e) }; }
}

// ── capture helpers ──────────────────────────────────────────────────────────
interface FileInfo { name: string; size: number; mtime: number; }

function jsonResponse(obj: unknown, status = 200): Response {
  return new Response(JSON.stringify(obj), {
    status,
    headers: { "Content-Type": "application/json", "Cache-Control": "no-cache" },
  });
}

// Single-quote a string for safe embedding inside a `bash -c` command.
function shq(s: string): string { return "'" + s.replace(/'/g, "'\\''") + "'"; }

// Minimal HTML-escape for untrusted text (capture filenames) in the page.
function esc(s: string): string {
  return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
}

function fmtSize(bytes: number): string {
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
  if (bytes < 1024 * 1024 * 1024) return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
  return `${(bytes / 1024 / 1024 / 1024).toFixed(2)} GB`;
}

function contentTypeFor(p: string): string {
  const e = p.toLowerCase();
  if (e.endsWith(".png")) return "image/png";
  if (e.endsWith(".jpg") || e.endsWith(".jpeg")) return "image/jpeg";
  if (e.endsWith(".gif")) return "image/gif";
  if (e.endsWith(".webp")) return "image/webp";
  if (e.endsWith(".mp4")) return "video/mp4";
  if (e.endsWith(".webm")) return "video/webm";
  if (e.endsWith(".mov")) return "video/quicktime";
  if (e.endsWith(".mkv")) return "video/x-matroska";
  if (e.endsWith(".txt") || e.endsWith(".log")) return "text/plain; charset=utf-8";
  return "application/octet-stream";
}

// Newest file in `dir` matching one of `exts`. Returns null when the directory
// is missing or empty — a missing capture folder is a normal pre-capture state.
async function latestFile(dir: string, exts: string[]): Promise<FileInfo | null> {
  let best: FileInfo | null = null;
  try {
    for await (const entry of Deno.readDir(dir)) {
      if (!entry.isFile) continue;
      const lower = entry.name.toLowerCase();
      if (!exts.some((x) => lower.endsWith(x))) continue;
      try {
        const st = await Deno.stat(`${dir}/${entry.name}`);
        const m = st.mtime?.getTime() ?? 0;
        if (!best || m > best.mtime) best = { name: entry.name, size: st.size, mtime: m };
      } catch { /* skip unstatable entry */ }
    }
  } catch { /* dir missing — normal before first capture */ }
  return best;
}

// ── adb device picker ──────────────────────────────────────────────────────
// Returns the serial of a usable adb device, or null if none reachable.
// Strategy:
//   1. Scan `adb devices`. Prefer the configured Tailscale TCP serial when
//      it's reporting "device" (handshake complete). Otherwise take the first
//      plain-USB serial.
//   2. Nothing usable? If TCP is stuck in "offline", `adb disconnect` then
//      `adb connect` to clear the stale handshake (necessary because raw
//      `adb connect` against an offline entry just hangs).
//   3. Still nothing? Bootstrap the phone's adbd TCP listener over SSH via
//      `nhere relay-prep`, wait for it to come up, retry the connect.
// Bounded throughout — never hangs longer than ~12 s in the worst case.
async function pickAdbDevice(): Promise<{ serial: string | null; reason?: string }> {
  const scan = async (): Promise<{ tcp: string | null; usb: string | null; offlineTcp: boolean }> => {
    const r = await run(["adb", "devices"], 2500);
    let tcp: string | null = null, usb: string | null = null, offlineTcp = false;
    if (!r.ok) return { tcp, usb, offlineTcp };
    for (const line of r.out.split("\n").slice(1)) { // skip header
      const m = line.match(/^(\S+)\s+(device|offline|unauthorized)/);
      if (!m) continue;
      const [, sn, state] = m;
      if (sn === ADB_SERIAL) {
        if (state === "device") tcp = sn;
        else if (state === "offline") offlineTcp = true;
      } else if (!sn.includes(":") && state === "device" && !usb) {
        usb = sn;
      }
    }
    return { tcp, usb, offlineTcp };
  };

  // Step 1: fast path — already-good device. Common case, returns in <1s.
  let s = await scan();
  if (s.tcp) return { serial: s.tcp };
  if (s.usb) return { serial: s.usb };

  // Step 2: local reconnect. Handles the stale-handshake case where TCP shows
  // "offline" even though the phone is actually reachable.
  if (s.offlineTcp) await run(["adb", "disconnect", ADB_SERIAL], 2000);
  await run(["adb", "connect", ADB_SERIAL], 3000);
  s = await scan();
  if (s.tcp) return { serial: s.tcp };
  if (s.usb) return { serial: s.usb };

  // Step 3: phone-side bootstrap via SSH. nhere relay-prep enables adbd TCP
  // on port 5555 on the phone. Only worth trying if SSH itself is reachable —
  // if the phone is asleep or off-Tailscale, this just adds latency, so the
  // SSH call uses a short ConnectTimeout via nhereOverSsh (4s) AND we cap
  // total relay-prep time. After it returns, give adbd a beat then reconnect.
  const relay = await nhereOverSsh("relay-prep");
  if (relay.ok) {
    await new Promise((r) => setTimeout(r, 2000));
    await run(["adb", "disconnect", ADB_SERIAL], 2000);
    await run(["adb", "connect", ADB_SERIAL], 3000);
    s = await scan();
    if (s.tcp) return { serial: s.tcp };
    if (s.usb) return { serial: s.usb };
  }

  return {
    serial: null,
    reason: relay.ok
      ? `relay-prep succeeded but adb still cannot reach ${ADB_SERIAL}; check phone`
      : `no adb device reachable. SSH to phone also failed (${relay.out.split("\n")[0] || "timeout"}). Phone may be asleep or off Tailscale.`,
  };
}

// ── nhere control plane ──────────────────────────────────────────────────────
// Whitelist of nhere sub-commands the cockpit will execute. Defense-in-depth
// against any future code that might forward an HTTP path or user input.
const NHERE_ALLOWED = new Set(["status", "arm", "disarm", "relay-prep"]);

type NherePath = "ssh" | "adb" | "none";
interface NhereResult { ok: boolean; out: string; path: NherePath; err?: string; }

async function nhereOverSsh(sub: string): Promise<NhereResult> {
  if (!NHERE_ALLOWED.has(sub)) return { ok:false, out:"", path:"ssh", err:"disallowed: " + sub };
  // Args are passed as a Deno argv array; only the trailing `su -c 'nhere <sub>'`
  // is a single string interpreted by the remote shell. `sub` is allowlisted, so
  // no injection vector exists.
  const r = await run(["ssh","-i",NHERE_KEY,"-o","BatchMode=yes","-o","StrictHostKeyChecking=accept-new","-o","ConnectTimeout=6","-p",NHERE_PORT,`${NHERE_USER}@${HOST_IP}`,`su -c 'nhere ${sub}'`]);
  return { ok: r.ok, out: r.out, path: "ssh" };
}

async function nhereOverAdb(sub: string): Promise<NhereResult> {
  if (!NHERE_ALLOWED.has(sub)) return { ok:false, out:"", path:"adb", err:"disallowed: " + sub };
  // Best-effort reconnect; harmless when already connected.
  await run(["adb","connect",ADB_SERIAL]);
  // adb shell joins its trailing argv into a remote shell command. `sub` is
  // allowlisted; no injection.
  const r = await run(["adb","-s",ADB_SERIAL,"shell","su","-c",`nhere ${sub}`]);
  return { ok: r.ok, out: r.out, path: "adb" };
}

// Control-path safety: SSH-first, ADB fallback. Returns the path that worked
// so callers/UI can show it to the operator.
async function nhereSafe(sub: string): Promise<NhereResult> {
  if (!NHERE_ALLOWED.has(sub)) return { ok:false, out:"", path:"none", err:"disallowed: " + sub };
  const s = await nhereOverSsh(sub);
  if (s.ok) return s;
  const a = await nhereOverAdb(sub);
  if (a.ok) return a;
  return {
    ok: false,
    path: "none",
    out: `--- ssh ---\n${s.out}\n--- adb ---\n${a.out}`,
    err: "both ssh and adb failed",
  };
}

async function getStatus(): Promise<Record<string, string>> {
  // Status uses the same safe runner so the cockpit stays informative even
  // after OFF (when SSH is intentionally down but ADB fallback may be up).
  const r = await nhereSafe("status");
  const fields: Record<string, string> = {};
  fields["target"] = `${NHERE_USER}@${HOST_IP}:${NHERE_PORT}`;
  fields["via"] = r.path;
  if (r.ok) {
    for (const line of r.out.split("\n")) {
      const m = line.match(/^(\w+):\s+(.+)$/);
      if (m) fields[m[1]] = m[2];
    }
  } else {
    fields["state"] = "unreachable";
    fields["error"] = (r.out || r.err || "").slice(0, 200);
  }
  return fields;
}

async function scrcpyInstalled(): Promise<boolean> {
  return (await run(["which", "scrcpy"])).ok;
}

async function startStream(): Promise<string> {
  if (isPidAlive(streamPid)) return `ok pid=${streamPid}`;
  try { await Deno.mkdir(STREAM_DIR, { recursive: true }); } catch { /**/ }
  for await (const e of Deno.readDir(STREAM_DIR)) {
    if (e.name.endsWith(".ts") || e.name.endsWith(".m3u8")) {
      try { await Deno.remove(`${STREAM_DIR}/${e.name}`); } catch { /**/ }
    }
  }
  const adb = new Deno.Command("adb", {
    args: ["-s", ADB_SERIAL, "exec-out", "screenrecord", "--output-format=h264", "--time-limit=3600", "-"],
    stdout: "piped", stderr: "null",
  }).spawn();
  const ff = new Deno.Command("ffmpeg", {
    args: ["-re","-i","pipe:0","-c:v","libx264","-preset","ultrafast","-tune","zerolatency","-vf","scale=540:-2","-f","hls","-hls_time","1","-hls_list_size","4","-hls_flags","delete_segments+omit_endlist",`${STREAM_DIR}/stream.m3u8`],
    stdin: "piped", stdout: "null", stderr: "null",
  }).spawn();
  adb.stdout.pipeTo(ff.stdin).catch(() => {});
  streamPid = ff.pid;
  ff.status.then(() => { streamPid = null; }).catch(() => { streamPid = null; });
  adb.status.catch(() => {});
  return `ok pid=${streamPid}`;
}

function stopStream(): void {
  killPid(streamPid); streamPid = null;
  (async () => {
    try {
      for await (const e of Deno.readDir(STREAM_DIR)) {
        if (e.name.endsWith(".ts") || e.name.endsWith(".m3u8")) try { await Deno.remove(`${STREAM_DIR}/${e.name}`); } catch { /**/ }
      }
    } catch { /**/ }
  })();
}

function buildHtml(fields: Record<string, string>, streamOn: boolean, relayAlive: boolean, recAlive: boolean, latestRec: FileInfo | null, latestShot: FileInfo | null): string {
  const rawState = fields["state"] ?? "unknown";
  const battery = fields["battery"] ?? "—";
  const root = fields["root"] ?? "—";
  const ts = fields["tailscale"] ?? "—";
  const sshd = fields["sshd"] ?? "—";
  const wakelock = fields["wakelock"] ?? "—";
  const time = fields["time"] ?? "—";

  // Normalise raw state → LIVE / OFF / UNKNOWN
  const isLive    = rawState === "armed";
  const isOff     = rawState === "disarmed";
  const state     = isLive ? "LIVE" : isOff ? "OFF" : "UNKNOWN";
  const bodyClass = isLive ? "state-live" : isOff ? "state-off" : "state-unknown";

  // Mac-side state labels for badges
  const screenLabel = relayAlive ? "live" : "off";
  const streamLabel = streamOn ? "running" : "stopped";
  const recLabel    = recAlive ? "recording" : "idle";

  // ── right preview rail data ──
  // Phone-preview badge tracks STREAM state: LIVE when streaming, OFFLINE when
  // not, UNKNOWN only when the device itself is unreachable.
  const streamBadge = streamOn ? "LIVE" : (state === "UNKNOWN" ? "UNKNOWN" : "OFFLINE");
  const streamCls   = streamOn ? "live" : (state === "UNKNOWN" ? "unknown" : "off");

  const recRows = (f: FileInfo) => `<div class="sg" style="margin-top:8px">
<div class="sr"><span class="sk">file</span><span class="sv">${esc(f.name)}</span></div>
<div class="sr"><span class="sk">time</span><span class="sv">${new Date(f.mtime).toISOString().slice(0, 19).replace("T", " ")}</span></div>
<div class="sr"><span class="sk">size</span><span class="sv">${fmtSize(f.size)}</span></div>
<div class="sr"><span class="sk">status</span><span class="sv${recAlive ? " up" : ""}">${recLabel}</span></div>
</div>`;
  const recPlayable = latestRec ? /\.(mp4|webm|mov)$/i.test(latestRec.name) : false;
  const recBody = latestRec
    ? (recPlayable
        ? `<video class="rvid" controls preload="metadata" src="/captures/Movies/${encodeURIComponent(latestRec.name)}"></video>${recRows(latestRec)}`
        : `<div class="rnote">File is not browser-playable</div>${recRows(latestRec)}`)
    : `<div class="rnote">No recording loaded yet</div>`;
  const shotSrc = latestShot ? `/captures/Screenshots/${encodeURIComponent(latestShot.name)}` : "";

  return `<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>nothinghere</title>
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest/dist/hls.min.js"></script>
