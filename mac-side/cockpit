.state-live::before{background:linear-gradient(90deg,transparent 0%,#facc15 20%,#fef08a 50%,#facc15 80%,transparent 100%);background-size:200% 100%;animation:bolt-slide 1.4s linear infinite;opacity:1;box-shadow:0 0 8px 2px #facc1566}
.state-degraded::before{background:linear-gradient(90deg,transparent,#fb923c,transparent);background-size:200% 100%;animation:bolt-slide 2.8s linear infinite;opacity:.6}
.state-dead::before{background:#1e1830;animation:none;opacity:.35;box-shadow:none}
