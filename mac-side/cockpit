  // Normalise raw state → LIVE / OFF / UNKNOWN
  const isLive    = rawState === "armed";
  const isOff     = rawState === "disarmed";
  const state     = isLive ? "LIVE" : isOff ? "OFF" : "UNKNOWN";
  const bodyClass = isLive ? "state-live" : isOff ? "state-off" : "state-unknown";

  // Mac-side state labels for badges
  const screenLabel = relayAlive ? "live" : "off";
  const streamLabel = streamOn ? "running" : "stopped";
  const recLabel    = recAlive ? "recording" : "idle";

  return `<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>nothinghere</title>
