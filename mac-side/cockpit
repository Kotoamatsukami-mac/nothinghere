<script>
let hls=null,hlsP=null,streamLive=${streamOn?"true":"false"};
// One HLS instance per video element: #vid (centre, large) + #vidp (rail phone).
function mountHls(v){
  if(!v)return null;const src='/stream/stream.m3u8';
  if(typeof Hls!=='undefined'&&Hls.isSupported()){
    const h=new Hls({lowLatencyMode:true,liveSyncDurationCount:2});
    h.loadSource(src);h.attachMedia(v);
    h.on(Hls.Events.MANIFEST_PARSED,()=>v.play().catch(()=>{}));
    h.on(Hls.Events.ERROR,(_,d)=>{if(d.fatal)applyStreamState(false);});
    return h;
  }
  if(v.canPlayType('application/vnd.apple.mpegurl')){v.src=src;v.play().catch(()=>{});}
  return null;
}
function show(id,on){const el=document.getElementById(id);if(el)el.style.display=on?'':'none';}
function setOnline(){
  show('vid',true);show('op',false);show('vidp',true);show('poff',false);
  if(hls)hls.destroy();hls=mountHls(document.getElementById('vid'));
  if(hlsP)hlsP.destroy();hlsP=mountHls(document.getElementById('vidp'));
  setPhoneBadge('LIVE','live');
}
function setOffline(){
  show('vid',false);show('op',true);show('vidp',false);show('poff',true);
  if(hls){hls.destroy();hls=null;}
  if(hlsP){hlsP.destroy();hlsP=null;}
  setPhoneBadge('OFFLINE','off');
}
function setPhoneBadge(text,cls){
  const b=document.getElementById('pbadge'),f=document.getElementById('pframe'),c=document.getElementById('pcard');
  if(b){b.textContent=text;b.className='pbadge '+cls;}
  if(f)f.className='pframe '+cls;
  if(c)c.className='card pcard '+cls;
}
// Single guarded entry point — only acts on a real state transition.
function applyStreamState(alive){if(alive===streamLive)return;streamLive=alive;alive?setOnline():setOffline();}
function logCon(msg){const el=document.getElementById('con');if(el){el.textContent=msg;el.scrollTop=el.scrollHeight;}}
function logErr(msg){const el=document.getElementById('err');if(!el)return;if(msg){el.textContent=msg;el.style.display='';}else{el.textContent='';el.style.display='none';}}
async function fetchText(route){
  try{const r=await fetch(route);const t=(await r.text()).trim();if(!r.ok){logErr(route+': '+(t||r.status));return null;}logErr('');return t;}
  catch(e){logErr(route+': '+String(e));return null;}
}
async function apiShow(route){logCon(route+'...');const t=await fetchText(route);if(t!==null)logCon(t);}
async function apiReload(route){logCon(route+'...');const t=await fetchText(route);if(t!==null){logCon(t);setTimeout(()=>location.reload(),600);}}
async function streamStart(){
  logCon('/stream-start...');
  const t=await fetchText('/stream-start');
  if(!t||!t.startsWith('ok')){if(t!==null)logCon(t);return;}
  logCon(t+'\nwaiting for manifest...');
  // Action-scoped retry: poll the manifest every 300 ms for up to ~7 s.
  // Runs ONLY after the user pressed Start Stream — not a global polling loop.
  const deadline=Date.now()+7200;
  while(Date.now()<deadline){
    try{const r=await fetch('/stream/stream.m3u8',{cache:'no-store'});if(r.ok){logCon(t+'\nmanifest ready');logErr('');applyStreamState(true);return;}}catch{}
    await new Promise(r=>setTimeout(r,300));
  }
  logErr('stream process started but manifest not ready after ~7s. Check the terminal cockpit is running in (or /tmp/cockpit.log if launched detached), then press Start Stream again.');
}
async function streamStop(){logCon('/stream-stop...');const t=await fetchText('/stream-stop');if(t!==null)logCon(t);applyStreamState(false);}
async function takeScreenshot(btn){
  const label=btn?btn.textContent:'';
  if(btn){btn.disabled=true;btn.textContent='capturing…';}
  logCon('/take-screenshot...');
  try{
    const r=await fetch('/take-screenshot',{cache:'no-store'});
    let j=null;try{j=await r.json();}catch{}
    logCon(j?JSON.stringify(j,null,2):('/take-screenshot: HTTP '+r.status));
    if(r.ok&&j&&j.ok&&j.url){
      const img=document.getElementById('shotImg'),empty=document.getElementById('shotEmpty');
      if(img){img.src=j.url+'?t='+Date.now();img.style.display='';}
      if(empty)empty.style.display='none';
      logErr('');
    }else{
      logErr('/take-screenshot: '+((j&&(j.message||j.error))||('HTTP '+r.status)));
    }
  }catch(e){logErr('/take-screenshot: '+String(e));}
  finally{if(btn){btn.disabled=false;btn.textContent=label;}}
}
function toggleFs(){const w=document.getElementById('vw');document.fullscreenElement?document.exitFullscreen():w.requestFullscreen().catch(()=>{});}
// Status polling: cheap pid check every 2s keeps the live/offline badges honest.
async function pollStream(){
  try{const r=await fetch('/stream.json',{cache:'no-store'});if(r.ok){const j=await r.json();applyStreamState(!!j.alive);}}catch{}
}
setInterval(pollStream,2000);
document.addEventListener('keydown',e=>{
  if(e.target.tagName==='INPUT')return;
  switch(e.key.toUpperCase()){
    case'L':apiReload('/arm');break;case'O':apiReload('/disarm');break;case'T':apiShow('/status');break;
    case'S':apiReload('/open-screen');break;case'X':apiReload('/close-screen');break;
    case'V':streamStart();break;case'Q':streamStop();break;
    case'R':apiShow('/record');break;case'P':apiShow('/ping');break;
    case' ':e.preventDefault();location.reload();break;
  }
});
${streamOn?"setOnline();":""}
</script></body></html>`;
}

async function handler(req: Request): Promise<Response> {
  const path = new URL(req.url).pathname;
  if (path.startsWith("/stream/")) {
    const fpath = `${STREAM_DIR}/${path.replace("/stream/","")}`;
    try {
      const data = await Deno.readFile(fpath);
      const ct = fpath.endsWith(".m3u8")?"application/vnd.apple.mpegurl":"video/mp2t";
      return new Response(data,{headers:{"Content-Type":ct,"Cache-Control":fpath.endsWith(".m3u8")?"no-cache":"max-age=2"}});
    } catch { return new Response("not found",{status:404}); }
  }
  if (path==="/stream.json") return new Response(JSON.stringify({alive:isPidAlive(streamPid),pid:streamPid}),{headers:{"Content-Type":"application/json","Cache-Control":"no-cache"}});
  if (path==="/stream-start") return new Response(await startStream(),{headers:{"Content-Type":"text/plain"}});
  if (path==="/stream-stop") { stopStream(); return new Response("stopped",{headers:{"Content-Type":"text/plain"}}); }
  if (path==="/"||path==="/index.html") {
    const fields=await getStatus();
    const latestRec=await latestFile(`${CAPTURES_DIR}/Movies`,[".mp4",".webm",".mov",".mkv"]);
    const latestShot=await latestFile(`${CAPTURES_DIR}/Screenshots`,[".png",".jpg",".jpeg"]);
    return new Response(buildHtml(fields,isPidAlive(streamPid),isPidAlive(relayPid),isPidAlive(recordingPid),latestRec,latestShot),{headers:{"Content-Type":"text/html; charset=utf-8","Cache-Control":"no-cache"}});
  }
  if (path==="/status.json") {
    const fields=await getStatus();
    return new Response(JSON.stringify({raw:Object.entries(fields).map(([k,v])=>`${k}:       ${v}`).join("\n"),fields}),{headers:{"Content-Type":"application/json","Cache-Control":"no-cache"}});
  }
  // LIVE — try SSH first, fall back to ADB. Re-armable even after OFF as long
  // as ADB TCP was bootstrapped before disarm (the /disarm precheck below
  // enforces that, but ADB may also be enabled manually).
  if (path === "/arm") {
    const r = await nhereSafe("arm");
    const body = `[path=${r.path}]\n${r.out || r.err || "arm ok"}`;
    return new Response(body, { status: r.ok ? 200 : 502, headers: { "Content-Type": "text/plain" } });
  }

  // OFF — guarded. Hard rule: the cockpit must not disable its only control
  // path. We refuse the disarm unless an ADB fallback is confirmed reachable.
  if (path === "/disarm") {
    let adbCheck = await nhereOverAdb("status");
    if (!adbCheck.ok) {
      // Try to bootstrap ADB TCP via the still-up SSH connection, then retry.
      const relay = await nhereOverSsh("relay-prep");
      if (relay.ok) {
        await new Promise((r) => setTimeout(r, 2500));
        adbCheck = await nhereOverAdb("status");
      }
    }
    if (!adbCheck.ok) {
      const msg = [
        "OFF refused: SSH would be stopped and no ADB fallback is reachable.",
        "Run relay-prep, connect USB ADB, or use physical Termux recovery.",
      ].join("\n");
      return new Response(msg, { status: 412, headers: { "Content-Type": "text/plain" } });
    }
    // ADB fallback confirmed. Run the actual disarm over ADB so the response
    // path is not killed by sshd shutdown.
    const r = await nhereOverAdb("disarm");
    const body = `[path=${r.path}]\n${r.out || (r.ok ? "disarm ok" : "disarm failed")}`;
    return new Response(body, { status: r.ok ? 200 : 500, headers: { "Content-Type": "text/plain" } });
  }

  // STATUS — same SSH-first / ADB-fallback contract as /arm.
  if (path === "/status") {
    const r = await nhereSafe("status");
    const body = `[path=${r.path}]\n${r.out || r.err || ""}`;
    return new Response(body, { status: r.ok ? 200 : 502, headers: { "Content-Type": "text/plain" } });
  }

  // RELAY-PREP — manual recovery: turn on ADB TCP via SSH. Useful before any
  // OFF if the operator has not pre-armed an ADB fallback.
  if (path === "/relay-prep") {
    const r = await nhereSafe("relay-prep");
    const body = `[path=${r.path}]\n${r.out || r.err || ""}`;
    return new Response(body, { status: r.ok ? 200 : 502, headers: { "Content-Type": "text/plain" } });
  }
  if (path==="/ping") {
    const r=await run(["ssh","-i",NHERE_KEY,"-o","BatchMode=yes","-o","StrictHostKeyChecking=accept-new","-o","ConnectTimeout=5","-p",NHERE_PORT,`${NHERE_USER}@${HOST_IP}`,"true"]);
    return new Response(r.ok?"reachable":"unreachable",{headers:{"Content-Type":"text/plain"}});
  }
  if (path==="/open-screen") {
    if (isPidAlive(relayPid)) return new Response(`relay running pid=${relayPid}`,{headers:{"Content-Type":"text/plain"}});
    if (!(await scrcpyInstalled())) {
      return new Response("scrcpy not installed\n  install: brew install scrcpy", {status:500, headers:{"Content-Type":"text/plain"}});
    }
    const pick = await pickAdbDevice();
    if (!pick.serial) {
      return new Response(`adb unavailable: ${pick.reason}`, {status:503, headers:{"Content-Type":"text/plain"}});
    }
    // Spawn detached so scrcpy does NOT block the cockpit server.
    const p=new Deno.Command("scrcpy",{args:["-s",pick.serial,"--stay-awake","--window-title","Nothing Live","--max-size","1280","--video-bit-rate","8M"],stdout:"null",stderr:"null",stdin:"null"}).spawn();
    relayPid=p.pid;
    p.status.then(()=>{relayPid=null;}).catch(()=>{relayPid=null;});
    return new Response(`ok pid=${relayPid} (device=${pick.serial})`,{headers:{"Content-Type":"text/plain"}});
  }
  if (path==="/close-screen") { killPid(relayPid); relayPid=null; return new Response("closed",{headers:{"Content-Type":"text/plain"}}); }
  if (path==="/record") {
    if (isPidAlive(recordingPid)) return new Response("already recording",{headers:{"Content-Type":"text/plain"}});
    if (!(await scrcpyInstalled())) {
      return new Response("scrcpy not installed\n  install: brew install scrcpy", {status:500, headers:{"Content-Type":"text/plain"}});
    }
    const pick=await pickAdbDevice();
    if (!pick.serial) return new Response(`adb unavailable: ${pick.reason}`,{status:503,headers:{"Content-Type":"text/plain"}});
    const ts=new Date().toISOString().replace(/[:.]/g,"-").slice(0,19);
    const out=`${RECORDINGS_DIR}/rec-${ts}.mp4`;
    const p=new Deno.Command("scrcpy",{args:["-s",pick.serial,"--no-display","--record",out],stdout:"null",stderr:"null",stdin:"null"}).spawn();
    recordingPid=p.pid;
    p.status.then(()=>{recordingPid=null;}).catch(()=>{recordingPid=null;});
    return new Response(`ok ${out} (device=${pick.serial})`,{headers:{"Content-Type":"text/plain"}});
  }
  if (path==="/stop-record") { killPid(recordingPid); recordingPid=null; return new Response("stopped",{headers:{"Content-Type":"text/plain"}}); }
  if (path==="/screenshot") {
    const pick=await pickAdbDevice();
    if (!pick.serial) return new Response(`adb unavailable: ${pick.reason}`,{status:503,headers:{"Content-Type":"text/plain"}});
    const ts=new Date().toISOString().replace(/[:.]/g,"-").slice(0,19);
    const out=`${RECORDINGS_DIR}/shot-${ts}.png`;
    const p=new Deno.Command("bash",{args:["-c",`adb -s ${shq(pick.serial)} exec-out screencap -p > ${shq(out)}`],stdout:"null",stderr:"null"});
    const {success}=await p.output();
    return new Response(success?`ok ${out}`:"failed",{headers:{"Content-Type":"text/plain"}});
  }
  // ── file pull routes ──────────────────────────────────────────────────────
  // Operator-visible capture pull. Every action logged to console.
  if (path==="/pull-recordings") {
    const dir=`${CAPTURES_DIR}/Movies`;
    await run(["mkdir","-p",dir]);
    const pick=await pickAdbDevice();
    if (!pick.serial) return new Response(`adb unavailable: ${pick.reason}`,{status:503,headers:{"Content-Type":"text/plain"}});
    const r=await run(["adb","-s",pick.serial,"pull","/sdcard/Movies/",dir+"/"]);
    return new Response(r.ok?`pulled → ${dir}\n${r.out}`:`pull failed\n${r.out}`,{status:r.ok?200:500,headers:{"Content-Type":"text/plain"}});
  }
  if (path==="/pull-screenshots") {
    const dir=`${CAPTURES_DIR}/Screenshots`;
    await run(["mkdir","-p",dir]);
    const pick=await pickAdbDevice();
    if (!pick.serial) return new Response(`adb unavailable: ${pick.reason}`,{status:503,headers:{"Content-Type":"text/plain"}});
    const r=await run(["adb","-s",pick.serial,"pull","/sdcard/Pictures/Screenshots/",dir+"/"]);
    return new Response(r.ok?`pulled → ${dir}\n${r.out}`:`pull failed\n${r.out}`,{status:r.ok?200:500,headers:{"Content-Type":"text/plain"}});
  }
  if (path==="/pull-downloads") {
    const dir=`${CAPTURES_DIR}/Download`;
    await run(["mkdir","-p",dir]);
    const pick=await pickAdbDevice();
    if (!pick.serial) return new Response(`adb unavailable: ${pick.reason}`,{status:503,headers:{"Content-Type":"text/plain"}});
    const r=await run(["adb","-s",pick.serial,"pull","/sdcard/Download/",dir+"/"]);
    return new Response(r.ok?`pulled → ${dir}\n${r.out}`:`pull failed\n${r.out}`,{status:r.ok?200:500,headers:{"Content-Type":"text/plain"}});
  }
  if (path==="/open-captures") {
    await run(["mkdir","-p",CAPTURES_DIR]);
    const r=await run(["open",CAPTURES_DIR]);
    return new Response(r.ok?`opened ${CAPTURES_DIR}`:`failed\n${r.out}`,{headers:{"Content-Type":"text/plain"}});
  }
  if (path==="/open-screenshots") {
    const dir=`${CAPTURES_DIR}/Screenshots`;
    await run(["mkdir","-p",dir]);
    const r=await run(["open",dir]);
    return new Response(r.ok?`opened ${dir}`:`failed\n${r.out}`,{headers:{"Content-Type":"text/plain"}});
  }
  // ── screenshot capture ────────────────────────────────────────────────────
  // Fast path: `adb exec-out screencap -p` writes the PNG straight to the Mac.
  // The redirection is done by bash (a subprocess), so it is not gated by
  // Deno's --allow-write scope. 15s timeout guards a wedged device.
  if (path==="/take-screenshot") {
    const macState = () => ({
      stream: isPidAlive(streamPid),
      screen: isPidAlive(relayPid),
      recorder: isPidAlive(recordingPid),
      captures_dir: CAPTURES_DIR,
    });
    const pick=await pickAdbDevice();
    if (!pick.serial) {
      return jsonResponse({ok:false,message:"adb device not connected",error:pick.reason,state:macState()},503);
    }
    const dir=`${CAPTURES_DIR}/Screenshots`;
    await run(["mkdir","-p",dir]);
    const d=new Date();
    const p2=(n:number)=>String(n).padStart(2,"0");
    const stamp=`${d.getFullYear()}${p2(d.getMonth()+1)}${p2(d.getDate())}_${p2(d.getHours())}${p2(d.getMinutes())}${p2(d.getSeconds())}`;
    const name=`screenshot_${stamp}.png`;
    const out=`${dir}/${name}`;
    const cap=await run(["bash","-c",`adb -s ${shq(pick.serial)} exec-out screencap -p > ${shq(out)}`],15000);
    let size=0;
    try { size=(await Deno.stat(out)).size; } catch { /* not written */ }
    // Verify a full PNG: 8-byte signature at the start AND the 8-byte IEND
    // chunk at the end. Guards against a truncated `screencap -p` that would
    // otherwise be cached as a "good" screenshot.
    let validPng=false;
    if (size>=24) {
      const sigBuf=new Uint8Array(8), endBuf=new Uint8Array(8);
      try {
        const f=await Deno.open(out,{read:true});
        try {
          await f.read(sigBuf);
          await f.seek(-8,Deno.SeekMode.End);
          await f.read(endBuf);
        } finally { f.close(); }
        const sigOk=sigBuf[0]===0x89&&sigBuf[1]===0x50&&sigBuf[2]===0x4e&&sigBuf[3]===0x47&&sigBuf[4]===0x0d&&sigBuf[5]===0x0a&&sigBuf[6]===0x1a&&sigBuf[7]===0x0a;
        // IEND chunk layout (last 12 bytes): 4B length, 4B "IEND" type, 4B CRC.
        // We read 8 bytes from offset -8, so type bytes land at [0..3].
        const endOk=endBuf[0]===0x49&&endBuf[1]===0x45&&endBuf[2]===0x4e&&endBuf[3]===0x44;
        validPng=sigOk&&endOk;
      } catch { /* leave validPng=false */ }
    }
    if (!cap.ok || !validPng) {
      try { if (size===0) await Deno.remove(out); } catch { /* best-effort */ }
      return jsonResponse({ok:false,message:"screenshot capture failed",error:cap.out||(size===0?"empty output file":"output is not a complete PNG"),state:{...macState(),size}},500);
    }
    return jsonResponse({
      ok:true,
      message:"Screenshot captured",
      file:out,
      url:`/captures/Screenshots/${encodeURIComponent(name)}`,
      state:{...macState(),size},
    });
  }
  // ── static capture serving ────────────────────────────────────────────────
  // Read-only. Serves regular files from CAPTURES_DIR only. Traversal is blocked
  // by rejecting ".." segments AND verifying the resolved real path stays inside
  // the capture root (defeats symlink escapes too).
  if (path.startsWith("/captures/")) {
    let rel:string;
    try { rel=decodeURIComponent(path.slice("/captures/".length)); }
    catch { return new Response("bad request",{status:400}); }
    if (rel==="" || rel.includes("\0") || rel.split("/").some((s)=>s===""||s==="..")) {
      return new Response("forbidden",{status:403});
    }
    let baseReal:string;
    try { baseReal=await Deno.realPath(CAPTURES_DIR); }
    catch { return new Response("not found",{status:404}); }
    let real:string;
    try { real=await Deno.realPath(`${CAPTURES_DIR}/${rel}`); }
    catch { return new Response("not found",{status:404}); }
    if (real!==baseReal && !real.startsWith(baseReal+"/")) {
      return new Response("forbidden",{status:403});
    }
    let st:Deno.FileInfo;
    try { st=await Deno.stat(real); }
    catch { return new Response("not found",{status:404}); }
    if (!st.isFile) return new Response("not found",{status:404});
    const ct=contentTypeFor(real);
    const size=st.size;
    // Range support so <video> playback and seeking work (Safari requires it).
    const rangeHeader=req.headers.get("range");
    const m=rangeHeader?rangeHeader.match(/^bytes=(\d*)-(\d*)$/):null;
    if (m) {
      let start:number,end:number;
      if (m[1]==="" && m[2]!=="") { start=Math.max(0,size-parseInt(m[2],10)); end=size-1; }
      else { start=m[1]?parseInt(m[1],10):0; end=m[2]?parseInt(m[2],10):size-1; }
      if (Number.isNaN(start)||Number.isNaN(end)||start>end||start<0||end>=size) {
        return new Response("range not satisfiable",{status:416,headers:{"Content-Range":`bytes */${size}`}});
      }
      const f=await Deno.open(real,{read:true});
      await f.seek(start,Deno.SeekMode.Start);
      let remaining=end-start+1;
      const body=new ReadableStream<Uint8Array>({
        async pull(ctrl){
          if (remaining<=0) { ctrl.close(); f.close(); return; }
          const buf=new Uint8Array(Math.min(65536,remaining));
          const n=await f.read(buf);
          if (n===null) { ctrl.close(); f.close(); return; }
          remaining-=n;
          ctrl.enqueue(buf.subarray(0,n));
        },
        cancel(){ try { f.close(); } catch { /* already closed */ } },
      });
      return new Response(body,{status:206,headers:{
        "Content-Type":ct,
        "Content-Length":String(end-start+1),
        "Content-Range":`bytes ${start}-${end}/${size}`,
        "Accept-Ranges":"bytes",
        "Cache-Control":"no-cache",
      }});
    }
    const f=await Deno.open(real,{read:true});
    return new Response(f.readable,{headers:{
      "Content-Type":ct,
      "Content-Length":String(size),
      "Accept-Ranges":"bytes",
      "Cache-Control":"no-cache",
    }});
  }
  return new Response("not found",{status:404});
}

