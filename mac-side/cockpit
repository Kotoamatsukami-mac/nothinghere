/* Streaming-offline overlay — scoped to .vw so the bare ".off" class on
   preview cards / badges / frames / buttons doesn't accidentally inherit
   position:absolute and stretch over the whole strip. */
.vw > .off{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;color:var(--muted);font-size:12px;position:absolute;inset:0;pointer-events:none}
.vw > .off svg{opacity:.15}.vw > .off span{opacity:.35;font-size:10px}
.fsb{position:absolute;bottom:10px;right:10px;background:rgba(255,255,255,.03);border:1px solid var(--border);color:var(--muted);border-radius:3px;padding:4px 8px;font-size:9px;font-family:var(--f);cursor:pointer;transition:all .1s;z-index:10;letter-spacing:.04em}
.fsb:hover{border-color:var(--muted);color:var(--text)}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

/* ── preview strip (under the stream pane) ── */
/* Plain flex row, explicit flex:1 1 0 per card so all three share the row
   equally regardless of content. Grid layout was getting overridden somewhere
   in the cascade — flex is simpler and more predictable here. */
.strip{display:flex;flex-direction:row;gap:8px;padding:10px;border-top:1px solid var(--border);background:var(--surface);flex-shrink:0;align-items:stretch}
.state-live .strip{border-top-color:rgba(0,255,65,.12)}
.strip > .card{flex:1 1 0;min-width:0;display:flex;flex-direction:column}
.pcard.live{border-color:rgba(0,255,65,.2)}
.pcard.unknown{border-color:rgba(249,115,22,.2)}
.rhead{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;gap:8px}
.rhead h2{margin-bottom:0}
.pbadge{font-size:8px;letter-spacing:.12em;padding:2px 7px;border-radius:2px;font-weight:600;border:1px solid var(--border);color:var(--muted);background:rgba(63,63,70,.1);flex-shrink:0}
.pbadge.live{color:var(--accent);background:rgba(0,255,65,.08);border-color:rgba(0,255,65,.3)}
.pbadge.off{color:var(--muted)}
.pbadge.unknown{color:var(--warn);background:rgba(249,115,22,.08);border-color:rgba(249,115,22,.3)}
/* Phone-frame mini-preview lives in the strip's first card. Keep it small so
   the whole strip stays compact under the main stream. */
.pframe{position:relative;width:100%;max-width:120px;aspect-ratio:9/19.5;margin:0 auto 6px;background:#0a0a0c;border:1px solid var(--muted);border-radius:14px;overflow:hidden;display:flex;align-items:center;justify-content:center;transition:border-color .4s,box-shadow .4s}
.pframe.live{border-color:var(--accent);box-shadow:0 0 10px rgba(0,255,65,.14)}
.pframe.off{border-color:var(--muted)}
.pframe.unknown{border-color:var(--warn)}
.pframe::before{content:'';position:absolute;top:5px;left:50%;transform:translateX(-50%);width:26px;height:3px;border-radius:2px;background:rgba(255,255,255,.07);z-index:2}
.pvid{width:100%;height:100%;object-fit:cover;display:block}
.poff{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:9px;letter-spacing:.06em;text-align:center;padding:0 4px}
