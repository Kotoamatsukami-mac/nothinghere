<script>
let hls=null;
function setupHls(){
  const v=document.getElementById('vid'),src='/stream/stream.m3u8';
  if(typeof Hls!=='undefined'&&Hls.isSupported()){
    if(hls)hls.destroy();
    hls=new Hls({lowLatencyMode:true,liveSyncDurationCount:2});
    hls.loadSource(src);hls.attachMedia(v);
    hls.on(Hls.Events.MANIFEST_PARSED,()=>v.play().catch(()=>{}));
    hls.on(Hls.Events.ERROR,(_,d)=>{if(d.fatal)setOffline();});
  }else if(v.canPlayType('application/vnd.apple.mpegurl')){v.src=src;v.play().catch(()=>{});}
}
function setOnline(){document.getElementById('vid').style.display='';document.getElementById('op').style.display='none';setupHls();}
function setOffline(){document.getElementById('vid').style.display='none';document.getElementById('op').style.display='';if(hls){hls.destroy();hls=null;}}
function logCon(msg){const el=document.getElementById('con');if(el){el.textContent=msg;el.scrollTop=el.scrollHeight;}}
function logErr(msg){const el=document.getElementById('err');if(!el)return;if(msg){el.textContent=msg;el.style.display='';}else{el.textContent='';el.style.display='none';}}
async function fetchText(route){
  try{const r=await fetch(route);const t=(await r.text()).trim();if(!r.ok){logErr(route+': '+(t||r.status));return null;}logErr('');return t;}
  catch(e){logErr(route+': '+String(e));return null;}
}
async function apiShow(route){logCon(route+'...');const t=await fetchText(route);if(t!==null)logCon(t);}
async function apiReload(route){logCon(route+'...');const t=await fetchText(route);if(t!==null){logCon(t);setTimeout(()=>location.reload(),600);}}
async function streamStart(){
  logCon('/stream-start...');
  const t=await fetchText('/stream-start');
  if(!t||!t.startsWith('ok')){if(t!==null)logCon(t);return;}
  logCon(t+'\nwaiting for manifest...');
  // Action-scoped retry: poll the manifest every 300 ms for up to ~7 s.
  // Runs ONLY after the user pressed Start Stream — not a global polling loop.
  const deadline=Date.now()+7200;
  while(Date.now()<deadline){
    try{const r=await fetch('/stream/stream.m3u8',{cache:'no-store'});if(r.ok){logCon(t+'\nmanifest ready');logErr('');setOnline();return;}}catch{}
    await new Promise(r=>setTimeout(r,300));
  }
  logErr('stream process started but manifest not ready after ~7s. Check /tmp/cockpit.log, then press Start Stream again.');
}
async function streamStop(){logCon('/stream-stop...');const t=await fetchText('/stream-stop');if(t!==null)logCon(t);setOffline();}
function toggleFs(){const w=document.getElementById('vw');document.fullscreenElement?document.exitFullscreen():w.requestFullscreen().catch(()=>{});}
