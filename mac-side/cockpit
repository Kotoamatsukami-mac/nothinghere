  const sshd = fields["sshd"] ?? "—";
  const wakelock = fields["wakelock"] ?? "—";
  const time = fields["time"] ?? "—";

  // Normalise raw state → LIVE / DEGRADED / DEAD
  const isLive     = rawState === "armed";
  const isDegraded = rawState === "degraded";
  const state      = isLive ? "LIVE" : isDegraded ? "DEGRADED" : "DEAD";
