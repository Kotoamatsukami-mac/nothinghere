#!/usr/bin/env bash
# mac-side/ctl — Slice 1 controller
#
# Usage:
#   ./mac-side/ctl [ping|status]
#   NHERE_PROFILE=<name> ./mac-side/ctl [ping|status]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

# --- Hard dependency preflight (before profile load) -------------------------
command -v tailscale &>/dev/null \
  || { echo "error: tailscale not found — install: brew install tailscale" >&2; exit 1; }

command -v ssh &>/dev/null \
  || { echo "error: ssh not found" >&2; exit 1; }

# --- Profile -----------------------------------------------------------------
PROFILE="${NHERE_PROFILE:-nothing-3a-pro}"
PROFILE_FILE="$REPO_ROOT/profiles/$PROFILE.conf"

[[ -f "$PROFILE_FILE" ]] \
  || { echo "error: profile not found: $PROFILE_FILE" >&2
       echo "  copy profiles/$PROFILE.example.conf → profiles/$PROFILE.conf and fill real values" >&2
       exit 1; }

# shellcheck source=/dev/null
source "$PROFILE_FILE"

: "${NHERE_HOST:?profile must define NHERE_HOST}"
: "${NHERE_PORT:?profile must define NHERE_PORT}"
: "${NHERE_USER:?profile must define NHERE_USER}"
: "${NHERE_KEY:?profile must define NHERE_KEY}"

# --- Key file preflight (after profile load) ---------------------------------
[[ -f "$NHERE_KEY" ]] \
  || { echo "error: key file not found: $NHERE_KEY" >&2
       echo "  generate: ssh-keygen -t ed25519 -f $NHERE_KEY -C nhere" >&2
       exit 1; }

# --- Config ------------------------------------------------------------------
CMD="${1:-status}"

SSH_OPTS=(
  -i "$NHERE_KEY"
  -o BatchMode=yes
  -o StrictHostKeyChecking=accept-new
  -o ConnectTimeout=8
  -p "$NHERE_PORT"
)

# --- Resolve target: prefer Tailscale hostname, fall back to IP --------------
resolve_target() {
  if tailscale ping -c 1 --timeout 4s "$NHERE_HOST" &>/dev/null 2>&1; then
    echo "$NHERE_HOST"
  elif [[ -n "${NHERE_HOST_IP:-}" ]]; then
    echo "warn: MagicDNS not resolving — using Tailscale IP fallback" >&2
    echo "$NHERE_HOST_IP"
  else
    echo "error: cannot resolve $NHERE_HOST and no IP fallback in profile" >&2
    exit 1
  fi
}

# --- Dispatch ----------------------------------------------------------------
case "$CMD" in
  ping)
    TARGET="$(resolve_target)"
    if ssh "${SSH_OPTS[@]}" "$NHERE_USER@$TARGET" true 2>/dev/null; then
      echo "reachable   $NHERE_HOST :$NHERE_PORT"
    else
      echo "unreachable $NHERE_HOST" >&2
      exit 1
    fi
    ;;

  status|arm|disarm|toggle|restart|relay-prep)
    TARGET="$(resolve_target)"
    [ "$CMD" = "status" ] && printf -- '--- %s ---\n' "$PROFILE"
    ssh "${SSH_OPTS[@]}" "$NHERE_USER@$TARGET" "su -c 'nhere $CMD'"
    ;;

  *)
    echo "usage: ctl [ping|status|arm|disarm|toggle|restart|relay-prep]" >&2
    exit 1
    ;;
esac
