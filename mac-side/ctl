#!/usr/bin/env bash
# mac-side/ctl — Slice 1 controller
#
# Usage:
#   ctl [ping|status]
#   NHERE_PROFILE=<name> ctl [ping|status]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

PROFILE="${NHERE_PROFILE:-nothing-3a-pro}"
PROFILE_FILE="$REPO_ROOT/profiles/$PROFILE.conf"

[[ -f "$PROFILE_FILE" ]] || { echo "error: profile not found: $PROFILE_FILE" >&2; exit 1; }
# shellcheck source=/dev/null
source "$PROFILE_FILE"

: "${NHERE_HOST:?profile must define NHERE_HOST}"
: "${NHERE_PORT:?profile must define NHERE_PORT}"
: "${NHERE_USER:?profile must define NHERE_USER}"
: "${NHERE_KEY:?profile must define NHERE_KEY}"

AGENT_PATH="${NHERE_AGENT_PATH:-~/nhere/agent}"
CMD="${1:-status}"

SSH_OPTS=(
  -i "$NHERE_KEY"
  -o BatchMode=yes
  -o StrictHostKeyChecking=accept-new
  -o ConnectTimeout=8
  -p "$NHERE_PORT"
)

# Resolve target: prefer Tailscale hostname, fall back to profile IP
resolve_target() {
  if tailscale ping -c 1 --timeout 4s "$NHERE_HOST" &>/dev/null 2>&1; then
    echo "$NHERE_HOST"
  elif [[ -n "${NHERE_HOST_IP:-}" ]]; then
    echo "warn: MagicDNS not resolving — using Tailscale IP fallback" >&2
    echo "$NHERE_HOST_IP"
  else
    echo "error: cannot resolve $NHERE_HOST and no IP fallback in profile" >&2
    exit 1
  fi
}

case "$CMD" in
  ping)
    TARGET="$(resolve_target)"
    if ssh "${SSH_OPTS[@]}" "$NHERE_USER@$TARGET" true 2>/dev/null; then
      echo "reachable   $NHERE_HOST :$NHERE_PORT"
    else
      echo "unreachable $NHERE_HOST" >&2
      exit 1
    fi
    ;;

  status)
    TARGET="$(resolve_target)"
    echo "--- $PROFILE ---"
    ssh "${SSH_OPTS[@]}" "$NHERE_USER@$TARGET" "sh $AGENT_PATH status"
    ;;

  *)
    echo "usage: ctl [ping|status]" >&2
    exit 1
    ;;
esac
